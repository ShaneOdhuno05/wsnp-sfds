# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ---- Throwaway verification runs ----
_val/
_val2/

# ---- Transient pipeline outputs (regenerated by simulator.py / n_simulator.py) ----
# windowed CSVs, encoded spike-trains, decision histories, per-run verdicts
**/windowed_packets-*.csv
**/encoded-*.txt
**/decision_history*.csv
**/output-decision_history.json

# ---- Capture run-logs & regenerated sweep plots (keep results_*.csv) ----
traffic_generation/experiments/*.caplog
sweep_results/*.png

# ---- Raw captures ----
# Keep the per-window CSVs that verify.py / simulator.py read; the raw pcaps are large,
# binary, and regenerable (scenario_runner.py), so they are not committed.
traffic_generation/experiments/*.pcap
